# SuperNova Environment Configuration
# Created: Phase 0 Environment Validation
# Will be expanded in Phase 3

# =============================================================================
# Core Application
# =============================================================================
SUPERNOVA_ENV=development
SUPERNOVA_LOG_LEVEL=INFO
SUPERNOVA_SECRET_KEY=dev-secret-key-change-in-production

# =============================================================================
# Database - PostgreSQL (Semantic Memory + Checkpoints)
# =============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=supernova
POSTGRES_USER=supernova
POSTGRES_PASSWORD=supernova_dev_password
DATABASE_URL=postgresql+asyncpg://supernova:supernova_dev_password@localhost:5432/supernova

# =============================================================================
# Episodic Memory - Neo4j
# =============================================================================
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=supernova_neo4j_dev

# =============================================================================
# Working Memory - Redis
# =============================================================================
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# =============================================================================
# LLM Provider API Keys (add your keys to enable real LLM calls)
# =============================================================================
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...
# COHERE_API_KEY=...

# LiteLLM proxy configuration
LITELLM_MASTER_KEY=sk-supernova-dev

# =============================================================================
# Observability - Langfuse
# =============================================================================
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

# =============================================================================
# MCP Configuration
# =============================================================================
MCP_CONFIG_PATH=./mcp_config.json

# =============================================================================
# Security & Operations
# =============================================================================
# Pickle HMAC key for secure deserialization (generate with: openssl rand -hex 32)
PICKLE_HMAC_KEY=dev-hmac-key-replace-in-production

# Encryption key for API keys at rest (generate with: openssl rand -hex 32)
API_KEY_ENCRYPTION_KEY=dev-encryption-key-replace-in-production

# Spending limit for LLM calls (USD per day)
DAILY_SPENDING_LIMIT=10.00
