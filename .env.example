# SuperNova Configuration
# Copy to .env and customize

# LLM (default: Ollama local — no API key needed)
# DEFAULT_MODEL=ollama/llama3.1
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Infrastructure (optional — not needed for minimal mode)
# NEO4J_URI=bolt://localhost:7687
# REDIS_URL=redis://localhost:6379
# DATABASE_URL=postgresql://supernova:supernova@localhost:5432/supernova

# Budget limits
# DAILY_BUDGET_USD=1.00
# MONTHLY_BUDGET_USD=10.00

# Security
# JWT_SECRET=change-me-in-production
# AUTONOMY_THRESHOLD=0.7
