# SuperNova Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control — it contains secrets!
# =============================================================================

# =============================================================================
# Core Application Settings
# =============================================================================

# Environment: development, staging, or production
SUPERNOVA_ENV=development

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
SUPERNOVA_LOG_LEVEL=INFO

# Secret key for cryptographic operations (generate with: openssl rand -hex 32)
# ⚠️ CRITICAL: Change this in production!
SUPERNOVA_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# Application host and port
SUPERNOVA_HOST=0.0.0.0
SUPERNOVA_PORT=8000

# =============================================================================
# Database — PostgreSQL (Semantic Memory + Checkpoints)
# =============================================================================

# Connection components (used to build DATABASE_URL if not provided)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=supernova
POSTGRES_USER=supernova
# ⚠️ Use strong password in production
POSTGRES_PASSWORD=supernova_dev_password

# Full async database URL (overrides components above if set)
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://supernova:supernova_dev_password@localhost:5432/supernova

# Connection pool settings
POSTGRES_POOL_SIZE=10
POSTGRES_MAX_OVERFLOW=20
POSTGRES_POOL_TIMEOUT=30

# =============================================================================
# Episodic Memory — Neo4j (Graphiti Temporal Knowledge Graph)
# =============================================================================

# Neo4j connection URI
# Format: bolt://host:port or neo4j://host:port for clustered setups
NEO4J_URI=bolt://localhost:7687

NEO4J_USER=neo4j
# ⚠️ Use strong password in production
NEO4J_PASSWORD=supernova_neo4j_dev

# Connection pool settings
NEO4J_MAX_CONNECTION_POOL_SIZE=50
NEO4J_CONNECTION_TIMEOUT=30

# =============================================================================
# Working Memory — Redis (Fast ephemeral storage + Celery broker)
# =============================================================================

# Redis connection URL
# Format: redis://[:password@]host[:port][/database]
REDIS_URL=redis://localhost:6379/0

# Optional Redis password (leave empty if no auth)
REDIS_PASSWORD=

# Redis for Celery (can be different instance)
REDIS_CELERY_URL=redis://localhost:6379/1

# Connection settings
REDIS_SOCKET_TIMEOUT=5
REDIS_SOCKET_CONNECT_TIMEOUT=5

# =============================================================================
# LLM Provider API Keys
# =============================================================================
# Add your API keys to enable real LLM calls.
# Get keys from respective provider dashboards.
# ⚠️ NEVER commit real API keys to version control!

# OpenAI — https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your-openai-key-here

# Anthropic — https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Google Gemini — https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=your-gemini-key-here

# Cohere — https://dashboard.cohere.com/api-keys
# COHERE_API_KEY=your-cohere-key-here

# Groq — https://console.groq.com/keys
# GROQ_API_KEY=gsk-your-groq-key-here

# =============================================================================
# LiteLLM Configuration (Universal LLM Proxy)
# =============================================================================

# Master key for LiteLLM proxy (generate random string)
LITELLM_MASTER_KEY=sk-supernova-dev-key-change-in-production

# LiteLLM proxy host (if using external proxy)
# LITELLM_PROXY_HOST=http://localhost:4000

# Default model for routing
LITELLM_DEFAULT_MODEL=gpt-4o-mini

# Fallback models (comma-separated)
LITELLM_FALLBACK_MODELS=gpt-3.5-turbo,claude-3-haiku-20240307

# =============================================================================
# Observability — Langfuse (Tracing and Monitoring)
# =============================================================================

# Get keys from Langfuse project settings
# https://cloud.langfuse.com or self-hosted instance

LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Langfuse host (use https://cloud.langfuse.com for cloud)
LANGFUSE_HOST=http://localhost:3000

# Enable/disable tracing
LANGFUSE_ENABLED=true

# Sample rate (1.0 = trace all, 0.1 = trace 10%)
LANGFUSE_SAMPLE_RATE=1.0

# =============================================================================
# MCP (Model Context Protocol) Configuration
# =============================================================================

# Path to MCP server configuration file
MCP_CONFIG_PATH=./mcp_config.json

# MCP server timeout in seconds
MCP_SERVER_TIMEOUT=30

# Enable MCP health checks
MCP_HEALTH_CHECK=true

# =============================================================================
# Security Settings
# =============================================================================

# Pickle HMAC key for secure deserialization (generate with: openssl rand -hex 32)
# ⚠️ CRITICAL: Must be same across all instances in production!
PICKLE_HMAC_KEY=dev-hmac-key-replace-with-openssl-rand-hex-32

# Encryption key for API keys at rest (generate with: openssl rand -hex 32)
# ⚠️ CRITICAL: Backup this key! Loss = irreversible data loss!
API_KEY_ENCRYPTION_KEY=dev-encryption-key-replace-with-openssl-rand-hex-32

# JWT token expiration in minutes
JWT_EXPIRATION_MINUTES=60

# CORS origins (comma-separated, use * only in development)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# =============================================================================
# Cost Management (CC-16, CC-17)
# =============================================================================

# Daily spending limit in USD (hard stop when exceeded)
DAILY_SPENDING_LIMIT=10.00

# Cost estimation threshold — user confirmation required above this amount
COST_CONFIRMATION_THRESHOLD=0.50

# Enable cost tracking
COST_TRACKING_ENABLED=true

# Alert when daily spend exceeds this percentage of limit
COST_ALERT_THRESHOLD_PERCENT=80

# =============================================================================
# Local Model Fallback (Ollama) — CC-18
# =============================================================================

# Enable local model fallback
OLLAMA_ENABLED=false

# Ollama host
OLLAMA_HOST=http://localhost:11434

# Default local model
OLLAMA_DEFAULT_MODEL=llama3.2:3b

# Fallback priority: local first, then cloud
LOCAL_MODEL_PRIORITY=false

# =============================================================================
# Backup & Recovery (CC-15)
# =============================================================================

# Enable automated daily backups
BACKUP_ENABLED=true

# Backup time (24-hour format, UTC)
BACKUP_TIME=02:00

# Backup retention in days
BACKUP_RETENTION_DAYS=30

# Backup storage path
BACKUP_PATH=./backups

# S3 backup (optional)
# BACKUP_S3_BUCKET=your-backup-bucket
# BACKUP_S3_PREFIX=supernova/
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# =============================================================================
# Audit Logging (CC-14)
# =============================================================================

# Enable audit logging
AUDIT_LOG_ENABLED=true

# Audit log destination: database, file, or both
AUDIT_LOG_DESTINATION=database

# Audit log file path (if destination includes 'file')
AUDIT_LOG_FILE_PATH=./logs/audit.log

# Log privileged actions only
AUDIT_LOG_PRIVILEGED_ONLY=false

# =============================================================================
# Sandbox Settings (CC-19)
# =============================================================================

# Code execution sandbox: docker, gvisor, or none (DANGEROUS)
CODE_SANDBOX=docker

# Docker image for code execution
CODE_SANDBOX_IMAGE=supernova-sandbox:latest

# Maximum execution time in seconds
CODE_EXECUTION_TIMEOUT=30

# Maximum memory for sandbox in MB
CODE_SANDBOX_MEMORY_MB=512

# =============================================================================
# Paths and Directories
# =============================================================================

# Workspace directory (jailed file access)
WORKSPACE_DIR=./workspace

# Logs directory
LOGS_DIR=./logs

# Skills directory
SKILLS_DIR=./supernova/skills

# Temporary directory
TEMP_DIR=/tmp/supernova

# =============================================================================
# Feature Flags
# =============================================================================

# Enable skill crystallization
FEATURE_SKILL_CRYSTALLIZATION=true

# Enable episodic memory
FEATURE_EPISODIC_MEMORY=true

# Enable semantic memory
FEATURE_SEMANTIC_MEMORY=true

# Enable human-in-the-loop interrupts
FEATURE_HITL_INTERRUPTS=true

# Enable demo mode (no API keys required)
FEATURE_DEMO_MODE=false

# =============================================================================
# Development Settings
# =============================================================================

# Hot reload on code changes
DEV_HOT_RELOAD=true

# Debug mode (verbose error messages)
DEV_DEBUG=false

# Profile performance
DEV_PROFILING=false

# Auto-restart workers on failure
DEV_AUTO_RESTART=true
