# ── Python bytecode and caches ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd

# ── Python tooling caches ───────────────────────────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/
supernova/.coverage
supernova/coverage.xml

# ── Virtual environments ─────────────────────────────────────────────────────
.venv/
venv/
env/
.env.local

# ── SECURITY: Environment files ──────────────────────────────────────────────
# .env.example is intentionally NOT ignored — it is the safe documentation copy.
# All other .env* variants contain secrets and must never be committed.
.env
.env.production
.env.staging
.env.*.local
*.env

# ── Build artifacts ──────────────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.whl
*.tar.gz

# ── Proof bundles and binary artifacts ───────────────────────────────────────
# Use GitHub Releases for distributable artifacts — not the source tree.
proof_bundle*/
proof_bundle_*.tar.gz

# ── Frontend build outputs ───────────────────────────────────────────────────
dashboard/node_modules/
dashboard/dist/
dashboard/.vite/
dashboard/test-results/
dashboard/playwright-report/

# ── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log

# ── Editor and OS temporaries ────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
*.orig
.idea/
.vscode/

# ── Pre-commit ───────────────────────────────────────────────────────────────
.pre-commit-home/
