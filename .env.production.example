# SuperNova — Production Environment Template
# =============================================================================
# Copy to .env and fill in real values before deploying.
# Validate before deploy: SUPERNOVA_ENV=production python scripts/validate_production_env.py
# =============================================================================

SUPERNOVA_ENV=production
SUPERNOVA_LOG_LEVEL=INFO
SUPERNOVA_SECRET_KEY=<generate-with-openssl-rand-hex-32>
SUPERNOVA_HOST=0.0.0.0
SUPERNOVA_PORT=8000

DATABASE_URL=postgresql+asyncpg://<user>:<password>@<host>:5432/supernova
POSTGRES_POOL_SIZE=20
POSTGRES_MAX_OVERFLOW=40

NEO4J_URI=bolt://<host>:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=<strong-password>

REDIS_URL=redis://:<password>@<host>:6379/0
REDIS_CELERY_URL=redis://:<password>@<host>:6379/1

OPENAI_API_KEY=<your-openai-key>
ANTHROPIC_API_KEY=<your-anthropic-key>
DEFAULT_MODEL=gpt-4o

LANGFUSE_PUBLIC_KEY=<your-langfuse-public-key>
LANGFUSE_SECRET_KEY=<your-langfuse-secret-key>
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_ENABLED=true
LANGFUSE_SAMPLE_RATE=1.0

COST_DAILY_SPENDING_LIMIT=25.00
COST_MONTHLY_SPENDING_LIMIT=500.00
COST_CONFIRMATION_THRESHOLD=0.50
COST_TRACKING_ENABLED=true
COST_ALERT_THRESHOLD_PERCENT=80

OLLAMA_ENABLED=true
OLLAMA_HOST=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.2:3b
LOCAL_MODEL_PRIORITY=false

BACKUP_ENABLED=true
BACKUP_TIME=02:00
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=./backups
BACKUP_S3_BUCKET=<your-backup-bucket>
BACKUP_S3_PREFIX=supernova/
BACKUP_S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=<your-aws-key>
AWS_SECRET_ACCESS_KEY=<your-aws-secret>

PICKLE_HMAC_KEY=<generate-with-openssl-rand-hex-32>
API_KEY_ENCRYPTION_KEY=<generate-with-openssl-rand-hex-32>
CORS_ORIGINS=https://your-domain.com

JWT_SECRET_KEY=<generate-with-openssl-rand-hex-32>
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60
