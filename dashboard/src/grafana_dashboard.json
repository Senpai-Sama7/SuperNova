  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Request Rate",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [{ "expr": "rate(http_requests_total[5m])", "legendFormat": "{{method}} {{path}}" }],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "title": "Request Latency (p50/p95)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        { "expr": "histogram_quantile(0.5, rate(http_request_duration_seconds_bucket[5m]))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))", "legendFormat": "p95" }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    },
    {
      "title": "Error Rate",
      "type": "stat",
      "datasource": "Prometheus",
      "targets": [{ "expr": "sum(rate(http_responses_total{status=~\"5..\"}[5m]))", "legendFormat": "5xx/s" }],
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 }
    },
    {
      "title": "Token Usage",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [{ "expr": "rate(llm_tokens_total[5m])", "legendFormat": "{{type}}" }],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 }
    },
    {
      "title": "Memory Hit Rates",
      "type": "gauge",
      "datasource": "Prometheus",
      "targets": [{ "expr": "memory_hit_rate", "legendFormat": "{{store}}" }],
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 }
    },
    {
      "title": "Service Health",
      "type": "stat",
      "datasource": "Prometheus",
      "targets": [{ "expr": "service_health_status", "legendFormat": "{{service}}" }],
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 8 }
    }
  ],
  "schemaVersion": 39,
  "tags": ["supernova", "observability"],
  "templating": { "list": [] },
